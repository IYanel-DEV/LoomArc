# Panel web server
PANEL_PORT=3000
PANEL_HOST=0.0.0.0

# Secret key — kept for legacy WebSocket compat; generate a random value
API_SECRET=change_me_to_a_long_random_string

# JWT secret for user authentication (change this to a long random string!)
JWT_SECRET=change_me_to_a_long_random_jwt_secret

# Default admin credentials created on first run (change after first login)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme123

# Absolute path where server data, JARs, and plugins are stored
# Leave blank to use ./data inside the project root
DATA_DIR=

# Java executable to use when launching servers
# Leave blank to auto-detect from PATH or JAVA_HOME
JAVA_PATH=

# Port allocation ranges
# BungeeCord proxies get ports in this range (one per network)
BUNGEE_PORT_START=25565
BUNGEE_PORT_END=25665

# Spigot backend servers get ports in this range
SERVER_PORT_START=25701
SERVER_PORT_END=26200

# Console output buffer per process (lines kept in memory)
CONSOLE_BUFFER_LINES=500

# How long (ms) to wait for graceful stop before SIGKILL
GRACEFUL_STOP_TIMEOUT=30000
